options gen2
options indenting = 4

require daslib/rtti

[export, pinvoke]
def can_visit_folder(folder_name : string; var result : bool?) {
    if (folder_name == "dasHV") {
        *result = has_module("dashv")
        return
    }
    if (folder_name == "dasPUGIXML") {
        *result = has_module("pugixml")
        return
    }
    if (folder_name == "dasSQLITE") {
        *result = has_module("sqlite")
        return
    }
    if (folder_name == "stbimage") {
        *result = has_module("stbimage")
        return
    }
    if (folder_name == "live_host") {
        *result = has_module("live_host")
        return
    }
    if (folder_name == "strudel") {
        *result = has_module("audio")
        return
    }
    if (folder_name == "jit_tests" || folder_name == ".jitted_scripts") {
        let args <- get_command_line_arguments()
        for (arg in args) {
            if (arg == "--use-aot") {
                *result = false
                return
            }
        }
    }
    // A meta-test that requires the compiler frontend at runtime (e.g. daslib/flatten ->
    // macro_boost) can't AOT-link in the full-tree batch, and one that runs qmacro at runtime
    // (flatten_optimize re-entry) carries quote nodes LLVM JIT can't codegen — interp only.
    if (folder_name == "no_aot") {
        let args <- get_command_line_arguments()
        for (arg in args) {
            if (arg == "--use-aot" || arg == "-jit") {
                *result = false
                return
            }
        }
    }
    if (folder_name == "ast_match" || folder_name == "ast") {
        let args <- get_command_line_arguments()
        for (arg in args) {
            if (arg == "--use-aot" || arg == "-jit") {
                *result = false
                return
            }
        }
    }
    if (folder_name == "gc") {
        let args <- get_command_line_arguments()
        for (arg in args) {
            if (arg == "-jit") {
                *result = false
                return
            }
        }
    }
    // The A/B baseline fixture keeps raw quote( ) nodes LLVM JIT can't codegen.
    // AOT stays on (the lowered twins are the point). Lift with the JIT lowering lane.
    if (folder_name == "quote") {
        let args <- get_command_line_arguments()
        for (arg in args) {
            if (arg == "-jit") {
                *result = false
                return
            }
        }
    }

}
