options gen2
options indenting = 4

require rtti
require strings

[export, pinvoke]
def can_visit_folder(folder_name : string; var result : bool?) {
    if (folder_name == "dasHV") {
        *result = has_module("dashv")
        return
    }
    if (folder_name == "dasPUGIXML") {
        *result = has_module("pugixml")
        return
    }
    if (folder_name == "jit_tests" || folder_name == "jitted_scripts") {
        let args <- get_command_line_arguments()
        for (arg in args) {
            if (arg == "--use-aot") {
                *result = false
                return
            }
        }
    }
}
