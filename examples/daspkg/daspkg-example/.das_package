options gen2

require daslib/daspkg

[export]
def package() {
    package_name("daspkg-example")
    package_description("Example project using daspkg")
}

[export]
def dependencies(version : string) {
    require_package("github.com/borisbat/daspkg-test-pure")
    require_package("github.com/borisbat/daspkg-test-deps")
}
