options gen2
require daslib/daspkg

[export]
def package() {
    package_name("furier")
    package_author("borisbat")
    package_description("Fourier epicycles — OpenGL viz + Dear ImGui controls, the ImGui-in-wasm examples showcase")
}

[export]
def dependencies(version : string) {
    require_package("dasImgui")
}

[export]
def release() {
    // The source lives one level up (shared examples/graphics tree); the cross-compile
    // roots dyn-module discovery at THIS package dir (-project-root) so the dasImgui dep
    // installed under furier/modules/ resolves. dashv is skipped on wasm (the harness
    // ?dashv-guards live_api), so a single source serves desktop live-reload and wasm64.
    release_main("../furier_opengl_imgui_example.das")
}
