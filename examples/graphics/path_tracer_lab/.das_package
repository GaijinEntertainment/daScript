options gen2
require daslib/daspkg

[export]
def package() {
    package_name("path_tracer_lab")
    package_author("borisbat")
    package_description("Path Tracer Lab — watch a path tracer fill in parallel: CPU single-thread, job queue, threads, or the GPU (fragment shader). OpenGL + Dear ImGui, jobque/threading showcase.")
}

[export]
def dependencies(version : string) {
    require_package("dasImgui")
}

[export]
def release() {
    // The source lives one level up (shared examples/graphics tree); the cross-compile roots
    // dyn-module discovery at THIS package dir (-project-root) so the dasImgui dep installed under
    // path_tracer_lab/modules/ resolves. dashv is skipped on wasm (the harness ?dashv-guards
    // live_api), so a single source serves desktop live-reload and the threaded wasm64 build.
    release_main("../path_tracer_lab_opengl_imgui_example.das")
}
