let private WS <- [
    9, 10, 11, 12, 13, 32, 133, 160, 5760, 8192, 8193, 8194, 8195, 8196, 8197, 8198,
    8199, 8200, 8201, 8202, 8232, 8233, 8239, 8287, 12288
]

// largest range whose start <= cpt, returns its category flag byte
def private range_flags(cpt : int) : int {
    var lo = 0
    var hi = length(RANGES) - 1
    while (lo < hi) {
        let mid = (lo + hi + 1) >> 1
        if ((RANGES[mid] >> 8) <= cpt) {
            lo = mid
        } else {
            hi = mid - 1
        }
    }
    return RANGES[lo] & 255
}

//! True if codepoint is a unicode letter (regex \p{L}).
def cpt_is_letter(cpt : int) : bool {
    return (range_flags(cpt) & 4) != 0
}

//! True if codepoint is a unicode number (regex \p{N}).
def cpt_is_number(cpt : int) : bool {
    return (range_flags(cpt) & 2) != 0
}

//! True if codepoint is whitespace (regex \s), per llama.cpp's whitespace set.
def cpt_is_whitespace(cpt : int) : bool {
    for (w in WS) {
        return true if (w == cpt)
    }
    return false
}

//! Decode a UTF-8 string into an array of codepoints. Malformed leads pass through
//! as a single byte (latin-1 style) — matches lenient tokenizer decoding.
def utf8_to_cpts(s : string) : array<int> {
    var cpts : array<int>
    peek_data(s) $(d : array<uint8> const#) {
        let n = length(d)
        var i = 0
        while (i < n) {
            let b0 = int(d[i])
            var cp = b0
            var extra = 0
            if (b0 >= 240) {
                cp = b0 & 7; extra = 3
            } elif (b0 >= 224) {
                cp = b0 & 15; extra = 2
            } elif (b0 >= 192) {
                cp = b0 & 31; extra = 1
            }
            i++
            var k = 0
            while (k < extra && i < n && (int(d[i]) & 192) == 128) {
                cp = (cp << 6) | (int(d[i]) & 63)
                i++
                k++
            }
            cpts |> push(cp)
        }
    }
    return <- cpts
}

//! Encode a single codepoint to its UTF-8 bytes as a string.
def cpt_to_utf8(cpt : int) : string {
    if (cpt < 128) {
        return string([uint8(cpt)])
    } elif (cpt < 2048) {
        return string([uint8(192 + (cpt >> 6)), uint8(128 + (cpt & 63))])
    } elif (cpt < 65536) {
        return string([uint8(224 + (cpt >> 12)), uint8(128 + ((cpt >> 6) & 63)), uint8(128 + (cpt & 63))])
    }
    return string([uint8(240 + (cpt >> 18)), uint8(128 + ((cpt >> 12) & 63)), uint8(128 + ((cpt >> 6) & 63)), uint8(128 + (cpt & 63))])
}
