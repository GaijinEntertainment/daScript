options gen2
require fio

[export]
def initialize(project_path : string) {
    if (das_is_dll_build()) {
        register_dynamic_module("{project_path}/dasModulePUGIXML.shared_module", "Module_PUGIXML")
    }
    register_native_path("pugixml", "PUGIXML_boost", "{project_path}/daslib/PUGIXML_boost.das")
}
