options gen2

require daslib/daspkg

[export]
def package() {
    package_name("dasGlfw")
}

[export]
def release() {
    // wasm (`daspkg release wasm`): emcc supplies the GLFW3 implementation at
    // link time; ignored by the native bundle path.
    release_emcc_arg("-sUSE_GLFW=3")
    let p = get_platform_name()
    if (p == "windows") {
        release_include_dll("glfw3.dll")
    } elif (p == "darwin") {
        release_include_dll("libglfw.3.4.dylib")
    } else {
        release_include_dll("libglfw.so.3.4")
    }
}
